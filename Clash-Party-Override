rules:
  # 局域网直连
  - "RULE-SET,LocalAreaNetwork,DIRECT"
  # 广告拦截
  - "RULE-SET,BanAD,REJECT"
  # AI 服务（不走香港）
  - "RULE-SET,OpenAI,AI-UNHK"
  - "RULE-SET,Anthropic,AI-UNHK"
  # Google FCM
  - "RULE-SET,GoogleFCM,谷歌FCM"
  - "RULE-SET,GoogleCN,谷歌FCM"
  # Steam CN 直连
  - "RULE-SET,SteamCN,DIRECT"
  # 微软服务
  - "RULE-SET,Bing,微软服务"
  - "RULE-SET,OneDrive,微软服务"
  - "RULE-SET,Microsoft,微软服务"
  # 苹果服务
  - "RULE-SET,Apple,苹果服务"
  # Telegram（域名 + IP 都要配）
  - "RULE-SET,TelegramDomain,电报消息"
  - "RULE-SET,Telegram,电报消息"
  # 游戏平台
  - "RULE-SET,Epic,游戏平台"
  - "RULE-SET,Steam,游戏平台"
  - "RULE-SET,Nintendo,游戏平台"
  # 流媒体
  - "RULE-SET,YouTube,油管视频"
  - "RULE-SET,Netflix,国外媒体"
  - "RULE-SET,ProxyMedia,国外媒体"
  # 代理域名
  - "RULE-SET,ProxyGFWlist,节点选择"
  # Garmin+strava
  - "DOMAIN,garmin.com,漏网之鱼"
  - "DOMAIN,connect.garmin.com,漏网之鱼"
  - "DOMAIN-SUFFIX,garmin.com,漏网之鱼"
  - "DOMAIN-SUFFIX,garmin.cn,漏网之鱼"
  - "DOMAIN-SUFFIX,strava.com,漏网之鱼"
  # 中国域名/IP 直连
  - "RULE-SET,ChinaDomain,DIRECT"
  - "RULE-SET,ChinaIP,DIRECT,no-resolve"
  # 兜底 GeoIP
  - "GEOIP,CN,DIRECT"
  - "MATCH,漏网之鱼"
